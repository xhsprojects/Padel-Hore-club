rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Utility Functions ---
    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthed() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Check if the user is the hardcoded super admin OR
      // if their role in the /users/{uid} document is 'admin'.
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      let isSuperAdmin = request.auth != null && request.auth.uid == 'sWO5cXkN9CcuwyhLTG3gfUmY0HH2';
      let isRoleAdmin = userDoc != null && 'role' in userDoc.data && userDoc.data.role == 'admin';
      return isSuperAdmin || isRoleAdmin;
    }

    // --- User Profile Rules ---
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) || isAdmin();
      
      // Admins can update anything.
      // Users can only update their own 'name', 'whatsapp', 'showWhatsapp', 'photoURL', and 'fcmTokens'.
      allow update: if isAdmin() || (
          isOwner(userId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'whatsapp', 'showWhatsapp', 'photoURL', 'fcmTokens'])
      );
      
      allow delete: if isAdmin();
      
      // --- Private User Data Subcollection ---
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if isAdmin();
      }
    }

    // --- Publicly Readable Collections ---
    match /courts/{courtId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /seasons/{seasonId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // --- Event Collections ---
    match /events/{eventId} {
        allow read: if true;
        // Admins can fully create/delete events.
        allow create, delete: if isAdmin();
        
        // Admins can update any field.
        // Authenticated users can ONLY update participant or waitlist arrays.
        allow update: if isAdmin() || (
            isAuthed() && 
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantIds', 'waitlistIds'])
        );

        // Registrations sub-collection rules.
        match /registrations/{registrationId} {
            allow read: if true;
            // Admins can create registrations for others. Users can only create their own.
            allow create: if isAdmin() || (isAuthed() && request.resource.data.userId == request.auth.uid);
            // Admins can update/delete any registration. Users can only update/delete their own.
            allow update, delete: if isAdmin() || (isAuthed() && resource.data.userId == request.auth.uid);
        }
    }
    
    // --- Shop & Order Collections ---
    match /products/{productId} {
        allow read: if true;
        allow write: if isAdmin();
    }

    match /orders/{orderId} {
        // Admins can read any order. Users can read their own.
        allow read: if isAdmin() || (isAuthed() && resource.data.userId == request.auth.uid);
        
        // Users can only create orders for themselves.
        allow create: if isOwner(request.resource.data.userId);
        
        // Only admins can update status or delete orders.
        allow update, delete: if isAdmin();
    }
  }
}
